#reload sxhkd
super + Escape
	reload

#kill dwm
super + shift + e
	pkill dwm

#screenshot
super + y
	scrot

#lock screen
super + s
	slock

#close a window
super + shift + q
	dwinkill

#play music
super + m
	musicmenu

#program launcher
super + d  
	dmenu_run -c -g 3 -l 5

#run teriminal
super + Return
	st

#file manager
super + f
	st -e lf

#email client
super + w
	st -e mutt

#copy text to clipboard
super + c
	copy

#change wallpaper
super + t
	paper

#manage usb drives
super + u
	udisksmenu

#dwm commands
super + {e,n}
	dwmc focusstack {-,+}1

super + {h,i}
	dwmc setmfact {-,+}0.05

super + b
	dwmc togglebar

super + space
	dwmc togglefloating

super + Tab
	dwmc view

super + shift + {t,f,m,d}
	dwmc setlayoutex {0,1,2,3}; \
	wmp 975 500

super + {_,ctrl +} {1-9}
	dwmc {_,toggle}viewex {0-8}; \
	wmp 975 500

super + shift + {_,ctrl +} {1-9}
	dwmc {_,toggle}tagex {0-8}

super + 0
	dwmc viewall

super + shift + 0
	dwmc tag .ui = ~0

super + z 
	dwmc zoom

super + {comma,period}
	dwmc focusmon {-,+}1

super + shift + {comma,period}
	dwmc tagmon {-,+}1
super + shift + p
	passmenu -c -l 6 -g 3
super + {l,p}
	dwmc incnmaster {+,-}1
